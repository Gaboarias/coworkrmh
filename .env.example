# ─── Base de datos (Neon Postgres) ────────────────────────────────────────────
# Cadena de conexión Postgres (Neon). En Vercel se inyecta automáticamente;
# en local copia este archivo a .env.local y rellena el valor real.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Autenticación (NextAuth) ─────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Necesario para reset de contraseña + notificaciones por correo (tarea asignada,
# proyecto agregado). Si no se define, los correos se omiten silenciosamente.
RESEND_API_KEY=

# URL base de la app (sin slash final). Usado para construir links absolutos en
# correos transaccionales. En Vercel se puede omitir — se usa VERCEL_URL
# automáticamente. En local setear a http://localhost:3000.
APP_URL=https://cowork-rmh.vercel.app

# Nota: el almacenamiento de archivos usa Vercel Blob; su token lo gestiona
# Vercel automáticamente en el entorno desplegado (BLOB_READ_WRITE_TOKEN).

# ─── Email Blaster (campañas masivas) ─────────────────────────────────────────
# API key SEPARADA del transaccional (reputación/cuota aisladas). Apuntá a un
# subdominio de marketing verificado en Resend (ej. mkt.rwndmedia.com). Si no se
# define, el blaster cae a RESEND_API_KEY — funciona, pero NO protege la
# entregabilidad del transaccional. Configurar en prod (ver PLAN Fase 4).
RESEND_MARKETING_API_KEY=

# Signing secret del webhook de Resend (Dashboard > Webhooks). Verifica la firma
# Svix de los eventos (open/click/bounce/complaint). Empieza con whsec_.
RESEND_WEBHOOK_SECRET=

# Secreto HMAC para el token del link de baja (stateless). Genera: openssl rand -hex 32
UNSUB_SECRET=

# Retención de email_events (días) antes de podarlos vía cron prune-email-events.
# Default 90 si no se define. Controla el crecimiento de storage del blaster en
# Neon. No afecta supresiones ni métricas por status (solo open/click de
# campañas más viejas que la ventana).
EMAIL_EVENTS_RETENTION_DAYS=90

# Protege el cron /api/cron/process-campaign (y check-due-soon). Vercel lo manda
# en el header Authorization automáticamente. Genera: openssl rand -hex 32
CRON_SECRET=

# ─── Integración de calendario (Google Calendar, OAuth read-only) ──────────────
# Credenciales de la app OAuth de Google Cloud Console (tipo "Web application").
# Scope: calendar.readonly + userinfo.email. Redirect URI autorizado:
#   https://cowork-rmh.vercel.app/api/calendar/google/callback
# Si NO se definen, la sección "Calendarios" en /settings aparece como
# "no configurado" y nada rompe.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Clave para cifrar (AES-256-GCM) los tokens OAuth guardados en DB. Cualquier
# string random sirve (se deriva a 32 bytes). Genera: openssl rand -hex 32
CALENDAR_TOKEN_ENC_KEY=
