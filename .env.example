# ─── Base de datos (Neon Postgres) ────────────────────────────────────────────
# Cadena de conexión Postgres (Neon). En Vercel se inyecta automáticamente;
# en local copia este archivo a .env.local y rellena el valor real.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Autenticación (NextAuth) ─────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Necesario para reset de contraseña + notificaciones por correo (tarea asignada,
# proyecto agregado). Si no se define, los correos se omiten silenciosamente.
RESEND_API_KEY=

# URL base de la app (sin slash final). Usado para construir links absolutos en
# correos transaccionales. En Vercel se puede omitir — se usa VERCEL_URL
# automáticamente. En local setear a http://localhost:3000.
APP_URL=https://cowork-rmh.vercel.app

# Nota: el almacenamiento de archivos usa Vercel Blob; su token lo gestiona
# Vercel automáticamente en el entorno desplegado (BLOB_READ_WRITE_TOKEN).
